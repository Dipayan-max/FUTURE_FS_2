<div class="crm-wrapper">
  <%- include('../partials/sidebar', { active: 'customers' }) %>

  <div class="crm-main">
    <%- include('../partials/topbar', { pageTitle: customer.name, pageSubtitle: customer.company || 'Customer Profile' }) %>

    <div class="crm-content">
      <%- include('../partials/messages') %>

      <!-- Back link -->
      <a href="/customers" class="btn btn-sm btn-outline-secondary mb-4"><i class="bi bi-arrow-left me-1"></i>Back to Customers</a>

      <div class="row g-4">
        <!-- Profile Card -->
        <div class="col-lg-4">
          <div class="dash-card mb-4">
            <div class="text-center mb-3">
              <div class="customer-avatar-lg mx-auto mb-3">
                <%= customer.name.charAt(0).toUpperCase() %>
              </div>
              <h5 class="fw-bold text-white mb-1"><%= customer.name %></h5>
              <p class="text-secondary small mb-2"><%= customer.company || 'No company' %></p>
              <span class="badge rounded-pill
                <% if (customer.status==='active') { %>bg-success-subtle text-success
                <% } else if (customer.status==='inactive') { %>bg-secondary-subtle text-secondary
                <% } else { %>bg-danger-subtle text-danger<% } %>
              "><%= customer.status %></span>
            </div>
            <hr class="border-secondary border-opacity-10" />
            <div class="d-flex flex-column gap-2">
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-envelope text-secondary" style="width:20px;"></i>
                <span class="small text-white"><%= customer.email || '—' %></span>
              </div>
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-telephone text-secondary" style="width:20px;"></i>
                <span class="small text-white"><%= customer.phone || '—' %></span>
              </div>
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-geo-alt text-secondary" style="width:20px;"></i>
                <span class="small text-white"><%= customer.address || '—' %></span>
              </div>
              <div class="d-flex align-items-center gap-2">
                <i class="bi bi-currency-dollar text-secondary" style="width:20px;"></i>
                <span class="small text-white fw-bold">$<%= (customer.totalRevenue || 0).toLocaleString() %></span>
              </div>
            </div>
            <hr class="border-secondary border-opacity-10" />
            <div class="d-flex gap-2">
              <button class="btn btn-sm btn-outline-primary flex-grow-1" data-bs-toggle="modal" data-bs-target="#editCustomerModal">
                <i class="bi bi-pencil me-1"></i>Edit
              </button>
              <button class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteCustomerModal">
                <i class="bi bi-trash"></i>
              </button>
            </div>
          </div>

          <!-- Notes Card -->
          <div class="dash-card" style="height:auto;">
            <h6 class="fw-bold text-white mb-3"><i class="bi bi-sticky me-2 text-warning"></i>Notes</h6>
            <% if (customer.notes) { %>
              <p class="text-secondary small mb-0" style="white-space:pre-wrap;overflow-wrap:break-word;word-break:break-word;"><%= customer.notes %></p>
            <% } else { %>
              <p class="text-secondary small mb-0">No notes yet. Edit the customer to add notes.</p>
            <% } %>
          </div>
        </div>

        <!-- Right: Interactions -->
        <div class="col-lg-8">
          <div class="dash-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="fw-bold text-white mb-0"><i class="bi bi-clock-history me-2 text-info"></i>Interactions</h6>
              <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addInteractionModal">
                <i class="bi bi-plus-lg me-1"></i>Add
              </button>
            </div>

            <% if (customer.interactions && customer.interactions.length > 0) { %>
              <div class="interaction-timeline">
                <% customer.interactions.forEach(function(i) { %>
                  <div class="interaction-item">
                    <div class="interaction-icon
                      <% if (i.type==='call') { %>bg-success-subtle text-success
                      <% } else if (i.type==='email') { %>bg-info-subtle text-info
                      <% } else if (i.type==='meeting') { %>bg-warning-subtle text-warning
                      <% } else { %>bg-primary-subtle text-primary<% } %>
                    ">
                      <% if (i.type==='call') { %><i class="bi bi-telephone"></i>
                      <% } else if (i.type==='email') { %><i class="bi bi-envelope"></i>
                      <% } else if (i.type==='meeting') { %><i class="bi bi-camera-video"></i>
                      <% } else { %><i class="bi bi-chat-text"></i><% } %>
                    </div>
                    <div class="flex-grow-1">
                      <div class="d-flex justify-content-between align-items-start">
                        <div>
                          <h6 class="text-white fw-semibold mb-1 small"><%= i.subject %></h6>
                          <% if (i.description) { %>
                            <p class="text-secondary small mb-1" style="white-space:pre-wrap;"><%= i.description %></p>
                          <% } %>
                          <small class="text-muted" style="font-size:0.7rem;">
                            <span class="badge bg-dark border border-secondary border-opacity-25 text-secondary me-1" style="font-size:0.65rem;"><%= i.type %></span>
                            <%= new Date(i.date).toLocaleDateString('en-US', {month:'short',day:'numeric',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                          </small>
                        </div>
                        <form action="/customers/<%= customer._id %>/interactions/<%= i._id %>/delete" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-link text-danger p-0" title="Delete">
                            <i class="bi bi-x-lg" style="font-size:0.75rem;"></i>
                          </button>
                        </form>
                      </div>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <div class="text-center py-4">
                <i class="bi bi-chat-square-text text-secondary" style="font-size:2rem;opacity:0.4;"></i>
                <p class="text-secondary small mt-2 mb-0">No interactions recorded yet</p>
              </div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- ========== EDIT CUSTOMER MODAL ========== -->
<div class="modal fade" id="editCustomerModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark border-secondary border-opacity-25" style="border-radius:16px;">
      <div class="modal-header border-secondary border-opacity-10">
        <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Customer</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/customers/<%= customer._id %>" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label small text-secondary">Name *</label>
              <input type="text" name="name" class="form-control bg-dark border-secondary border-opacity-25 text-white" value="<%= customer.name %>" required />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Email</label>
              <input type="email" name="email" class="form-control bg-dark border-secondary border-opacity-25 text-white" value="<%= customer.email || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Phone</label>
              <input type="text" name="phone" class="form-control bg-dark border-secondary border-opacity-25 text-white" value="<%= customer.phone || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Company</label>
              <input type="text" name="company" class="form-control bg-dark border-secondary border-opacity-25 text-white" value="<%= customer.company || '' %>" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Status</label>
              <select name="status" class="form-select bg-dark border-secondary border-opacity-25 text-white">
                <option value="active" <%= customer.status==='active' ? 'selected' : '' %>>Active</option>
                <option value="inactive" <%= customer.status==='inactive' ? 'selected' : '' %>>Inactive</option>
                <option value="churned" <%= customer.status==='churned' ? 'selected' : '' %>>Churned</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Revenue ($)</label>
              <input type="number" name="totalRevenue" class="form-control bg-dark border-secondary border-opacity-25 text-white" value="<%= customer.totalRevenue || 0 %>" min="0" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Address</label>
              <input type="text" name="address" class="form-control bg-dark border-secondary border-opacity-25 text-white" value="<%= customer.address || '' %>" />
            </div>
            <div class="col-12">
              <label class="form-label small text-secondary">Notes</label>
              <textarea name="notes" rows="3" class="form-control bg-dark border-secondary border-opacity-25 text-white"><%= customer.notes || '' %></textarea>
            </div>
          </div>
        </div>
        <div class="modal-footer border-secondary border-opacity-10">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Changes</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ========== ADD INTERACTION MODAL ========== -->
<div class="modal fade" id="addInteractionModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark border-secondary border-opacity-25" style="border-radius:16px;">
      <div class="modal-header border-secondary border-opacity-10">
        <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2 text-info"></i>Add Interaction</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/customers/<%= customer._id %>/interactions" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label small text-secondary">Type</label>
              <select name="type" class="form-select bg-dark border-secondary border-opacity-25 text-white">
                <option value="note">📝 Note</option>
                <option value="call">📞 Call</option>
                <option value="email">📧 Email</option>
                <option value="meeting">📹 Meeting</option>
                <option value="other">📌 Other</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Date</label>
              <input type="datetime-local" name="date" class="form-control bg-dark border-secondary border-opacity-25 text-white" />
            </div>
            <div class="col-12">
              <label class="form-label small text-secondary">Subject *</label>
              <input type="text" name="subject" class="form-control bg-dark border-secondary border-opacity-25 text-white" placeholder="Brief summary..." required />
            </div>
            <div class="col-12">
              <label class="form-label small text-secondary">Description</label>
              <textarea name="description" rows="3" class="form-control bg-dark border-secondary border-opacity-25 text-white" placeholder="Details..."></textarea>
            </div>
          </div>
        </div>
        <div class="modal-footer border-secondary border-opacity-10">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Add</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ========== DELETE CUSTOMER MODAL ========== -->
<div class="modal fade" id="deleteCustomerModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content bg-dark border-danger border-opacity-25" style="border-radius:16px;">
      <div class="modal-body text-center py-4">
        <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:2.5rem;"></i>
        <h5 class="fw-bold text-white mb-2 mt-3">Delete Customer</h5>
        <p class="text-secondary small">Delete <strong class="text-white"><%= customer.name %></strong> and all their interactions? This cannot be undone.</p>
      </div>
      <div class="modal-footer border-secondary border-opacity-10 justify-content-center">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <form action="/customers/<%= customer._id %>/delete" method="POST" class="d-inline">
          <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

<style>
  .customer-avatar-lg {
    width: 72px;
    height: 72px;
    border-radius: 18px;
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 800;
    font-size: 1.8rem;
    color: #fff;
  }
  .interaction-timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .interaction-item {
    display: flex;
    gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(148,163,184,0.06);
  }
  .interaction-item:last-child { border-bottom: none; }
  .interaction-icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    flex-shrink: 0;
  }
</style>
