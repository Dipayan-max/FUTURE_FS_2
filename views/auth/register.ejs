<div class="auth-page">
  <!-- Animated background -->
  <div class="auth-bg-orb auth-bg-orb-1"></div>
  <div class="auth-bg-orb auth-bg-orb-2"></div>
  <div class="auth-bg-orb auth-bg-orb-3"></div>
  <div class="auth-grid-overlay"></div>

  <div class="auth-container">
    <div class="auth-split">

      <!-- LEFT: Feature Panel -->
      <div class="auth-feature-panel d-none d-lg-flex">
        <div class="auth-feature-content">
          <div class="auth-feature-badge">
            <i class="bi bi-lightning-charge-fill me-1"></i>ULTRA CRM
          </div>
          <h2 class="auth-feature-title">Start growing<br/>your business today</h2>
          <p class="auth-feature-desc">Join thousands of teams using ULTRA CRM to manage contacts, close deals faster, and boost revenue.</p>

          <div class="auth-feature-stats">
            <div class="auth-feature-stat">
              <div class="auth-feature-stat-value">Free</div>
              <div class="auth-feature-stat-label">To Start</div>
            </div>
            <div class="auth-feature-stat">
              <div class="auth-feature-stat-value">2 min</div>
              <div class="auth-feature-stat-label">Setup</div>
            </div>
            <div class="auth-feature-stat">
              <div class="auth-feature-stat-value">∞</div>
              <div class="auth-feature-stat-label">Contacts</div>
            </div>
          </div>

          <div class="auth-feature-checklist">
            <div class="auth-check-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Unlimited contacts & leads</div>
            <div class="auth-check-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Real-time analytics dashboard</div>
            <div class="auth-check-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Interaction tracking & notes</div>
            <div class="auth-check-item"><i class="bi bi-check-circle-fill text-success me-2"></i>Team collaboration tools</div>
          </div>
        </div>
      </div>

      <!-- RIGHT: Register Form -->
      <div class="auth-form-panel">
        <div class="auth-form-inner">

          <!-- Mobile-only brand -->
          <div class="text-center mb-4 d-lg-none auth-fade-in" style="animation-delay:0.1s">
            <div class="auth-logo-wrap mx-auto mb-3">
              <i class="bi bi-lightning-charge-fill"></i>
            </div>
          </div>

          <div class="auth-fade-in" style="animation-delay:0.15s">
            <h1 class="auth-form-title">Create account</h1>
            <p class="auth-form-subtitle">Get started for free — no credit card required</p>
          </div>

          <!-- Flash Messages -->
          <div class="auth-fade-in" style="animation-delay:0.2s">
            <%- include('../partials/messages') %>
          </div>

          <!-- Form -->
          <div class="auth-fade-in" style="animation-delay:0.3s">
            <form action="/auth/register" method="POST" class="needs-validation" novalidate>

              <!-- Name -->
              <div class="auth-field">
                <label class="auth-field-label" for="name">Full name</label>
                <div class="auth-input-wrap">
                  <i class="bi bi-person auth-input-icon"></i>
                  <input type="text" class="auth-input" id="name" name="name"
                         placeholder="John Doe" value="<%= typeof name !== 'undefined' ? name : '' %>" required />
                </div>
                <div class="invalid-feedback">Please enter your name.</div>
              </div>

              <!-- Email -->
              <div class="auth-field">
                <label class="auth-field-label" for="email">Email address</label>
                <div class="auth-input-wrap">
                  <i class="bi bi-envelope auth-input-icon"></i>
                  <input type="email" class="auth-input" id="email" name="email"
                         placeholder="you@company.com" value="<%= typeof email !== 'undefined' ? email : '' %>" required />
                </div>
                <div class="invalid-feedback">Please enter a valid email.</div>
              </div>

              <!-- Password -->
              <div class="auth-field">
                <label class="auth-field-label" for="password">Password</label>
                <div class="auth-input-wrap">
                  <i class="bi bi-lock auth-input-icon"></i>
                  <input type="password" class="auth-input" id="password" name="password"
                         placeholder="Min 6 characters" required minlength="6" />
                  <button type="button" class="auth-toggle-pw" onclick="togglePassword('password', this)" tabindex="-1">
                    <i class="bi bi-eye-slash"></i>
                  </button>
                </div>
                <div class="invalid-feedback">Minimum 6 characters.</div>
              </div>

              <!-- Confirm Password -->
              <div class="auth-field">
                <label class="auth-field-label" for="password2">Confirm password</label>
                <div class="auth-input-wrap">
                  <i class="bi bi-shield-lock auth-input-icon"></i>
                  <input type="password" class="auth-input" id="password2" name="password2"
                         placeholder="Re-enter password" required minlength="6" />
                  <button type="button" class="auth-toggle-pw" onclick="togglePassword('password2', this)" tabindex="-1">
                    <i class="bi bi-eye-slash"></i>
                  </button>
                </div>
                <div class="invalid-feedback">Passwords must match.</div>
              </div>

              <!-- Terms -->
              <div class="form-check mb-4">
                <input class="form-check-input" type="checkbox" id="terms" required />
                <label class="form-check-label small text-secondary" for="terms">
                  I agree to the <a href="#" class="auth-link">Terms</a> &amp; <a href="#" class="auth-link">Privacy Policy</a>
                </label>
                <div class="invalid-feedback">You must agree before submitting.</div>
              </div>

              <!-- Submit -->
              <button type="submit" class="btn auth-btn w-100">
                <span class="auth-btn-text">Create Account <i class="bi bi-arrow-right ms-1"></i></span>
                <span class="auth-btn-loader d-none">
                  <span class="spinner-border spinner-border-sm me-2"></span>Creating...
                </span>
              </button>
            </form>


          </div>

          <!-- Footer -->
          <p class="text-center text-secondary small mt-4 auth-fade-in" style="animation-delay:0.5s">
            Already have an account?
            <a href="/auth/login" class="auth-link fw-semibold">Sign in</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function togglePassword(id, btn) {
  const input = document.getElementById(id);
  const icon = btn.querySelector('i');
  if (input.type === 'password') { input.type = 'text'; icon.className = 'bi bi-eye'; }
  else { input.type = 'password'; icon.className = 'bi bi-eye-slash'; }
}
(function () {
  const forms = document.querySelectorAll('.needs-validation');
  forms.forEach(f => f.addEventListener('submit', e => {
    const pw = f.querySelector('#password'), pw2 = f.querySelector('#password2');
    if (pw && pw2 && pw.value !== pw2.value) { pw2.setCustomValidity('Mismatch'); } else if (pw2) { pw2.setCustomValidity(''); }
    if (!f.checkValidity()) { e.preventDefault(); e.stopPropagation(); }
    else { f.querySelector('.auth-btn-text').classList.add('d-none'); f.querySelector('.auth-btn-loader').classList.remove('d-none'); }
    f.classList.add('was-validated');
  }));
})();
</script>
