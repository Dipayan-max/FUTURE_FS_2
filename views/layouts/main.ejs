<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="ULTRA CRM - Customer Relationship Management Application" />
  <title><%= typeof title !== 'undefined' ? title + ' | ULTRA CRM' : 'ULTRA CRM' %></title>

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- Bootstrap 5.3 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/auth.css" />
  <link rel="stylesheet" href="/css/dashboard.css" />

  <!-- Apply saved theme BEFORE render to prevent flash -->
  <script>
    (function() {
      if (localStorage.getItem('crm-dark-mode') === 'false') {
        document.documentElement.setAttribute('data-bs-theme', 'light');
        document.documentElement.classList.add('light-mode-html');
      }
      if (localStorage.getItem('crm-compact') === 'true') {
        document.documentElement.classList.add('compact-mode-html');
      }
    })();
  </script>
</head>
<body>
  <%- body %>

  <!-- Bootstrap 5.3 JS Bundle -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

  <!-- Global theme initializer — runs on every page -->
  <script>
    (function() {
      // Apply classes to body (CSS selectors use body.light-mode)
      if (localStorage.getItem('crm-dark-mode') === 'false') {
        document.body.classList.add('light-mode');
        document.documentElement.setAttribute('data-bs-theme', 'light');
      }
      if (localStorage.getItem('crm-compact') === 'true') {
        document.body.classList.add('compact-mode');
      }

      // Keep settings page toggles in sync if present
      var dt = document.getElementById('darkModeToggle');
      if (dt) {
        dt.checked = localStorage.getItem('crm-dark-mode') !== 'false';
        dt.addEventListener('change', function() {
          if (this.checked) {
            document.body.classList.remove('light-mode');
            document.documentElement.setAttribute('data-bs-theme', 'dark');
            localStorage.setItem('crm-dark-mode', 'true');
          } else {
            document.body.classList.add('light-mode');
            document.documentElement.setAttribute('data-bs-theme', 'light');
            localStorage.setItem('crm-dark-mode', 'false');
          }
        });
      }

      var ct = document.getElementById('compactToggle');
      if (ct) {
        ct.checked = localStorage.getItem('crm-compact') === 'true';
        ct.addEventListener('change', function() {
          document.body.classList.toggle('compact-mode', this.checked);
          localStorage.setItem('crm-compact', this.checked ? 'true' : 'false');
        });
      }
    })();
  </script>
</body>
</html>
