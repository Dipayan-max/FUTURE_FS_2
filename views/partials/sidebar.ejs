<aside class="crm-sidebar" id="crmSidebar">
  <!-- Brand -->
  <div class="sidebar-brand">
    <div class="d-flex align-items-center gap-2">
      <div class="brand-icon">
        <i class="bi bi-lightning-charge-fill"></i>
      </div>
      <div>
        <h5 class="mb-0 fw-bold text-white">ULTRA CRM</h5>
        <span class="small text-secondary">Management Suite</span>
      </div>
    </div>
  </div>

  <!-- Navigation -->
  <nav class="sidebar-nav flex-grow-1">
    <div class="nav-section-label">Main Menu</div>
    <ul class="nav flex-column">
      <li class="nav-item">
        <a href="/dashboard" class="nav-link <%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>">
          <i class="bi bi-grid-1x2-fill"></i>
          <span>Dashboard</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/contacts" class="nav-link <%= typeof active !== 'undefined' && active === 'contacts' ? 'active' : '' %>">
          <i class="bi bi-people-fill"></i>
          <span>Contacts</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/leads" class="nav-link <%= typeof active !== 'undefined' && active === 'leads' ? 'active' : '' %>">
          <i class="bi bi-funnel-fill"></i>
          <span>Leads</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/customers" class="nav-link <%= typeof active !== 'undefined' && active === 'customers' ? 'active' : '' %>">
          <i class="bi bi-person-check-fill"></i>
          <span>Customers</span>
        </a>
      </li>
    </ul>

    <div class="nav-section-label mt-3">Quick Actions</div>
    <ul class="nav flex-column">
      <li class="nav-item">
        <a href="/contacts/add" class="nav-link <%= typeof active !== 'undefined' && active === 'add-contact' ? 'active' : '' %>">
          <i class="bi bi-plus-circle-fill"></i>
          <span>Add Contact</span>
        </a>
      </li>
      <li class="nav-item">
        <a href="/settings" class="nav-link <%= typeof active !== 'undefined' && active === 'settings' ? 'active' : '' %>">
          <i class="bi bi-gear-fill"></i>
          <span>Settings</span>
        </a>
      </li>
    </ul>
  </nav>

  <!-- User Footer -->
  <div class="sidebar-user">
    <% if (typeof user !== 'undefined' && user) { %>
      <div class="d-flex align-items-center gap-2 mb-2">
        <div class="user-avatar-sm">
          <%= user.name.charAt(0).toUpperCase() %>
        </div>
        <div class="flex-grow-1 overflow-hidden">
          <div class="fw-semibold text-white small text-truncate"><%= user.name %></div>
          <div class="text-secondary" style="font-size:0.7rem;text-transform:capitalize;"><%= user.role %></div>
        </div>
      </div>
    <% } %>
    <a href="/auth/logout" class="btn btn-outline-secondary btn-sm w-100">
      <i class="bi bi-box-arrow-left me-1"></i>Logout
    </a>
  </div>
</aside>
