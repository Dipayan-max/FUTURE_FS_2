<div class="crm-wrapper">
  <%- include('../partials/sidebar', { active: 'leads' }) %>

  <div class="crm-main">
    <%- include('../partials/topbar', { pageTitle: 'Leads', pageSubtitle: 'Manage your sales pipeline' }) %>

    <div class="crm-content">
      <%- include('../partials/messages') %>

      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div class="d-flex align-items-center gap-3 flex-wrap">
          <!-- Live Search -->
          <div class="topbar-search">
            <i class="bi bi-search"></i>
            <input type="text" class="form-control" id="leadSearch" placeholder="Search leads..." autocomplete="off" />
          </div>
          <!-- Status Filter Pills -->
          <div class="d-flex gap-1 flex-wrap" id="statusFilters">
            <button class="badge rounded-pill py-2 px-3 border-0 filter-pill active" data-status="all">All</button>
            <button class="badge rounded-pill py-2 px-3 border-0 filter-pill" data-status="lead">Lead</button>
            <button class="badge rounded-pill py-2 px-3 border-0 filter-pill" data-status="prospect">Prospect</button>
          </div>
          <!-- Sort Toggle -->
          <button class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" id="sortToggle" title="Toggle sort order">
            <i class="bi bi-sort-down" id="sortIcon"></i>
            <span class="small" id="sortLabel">Newest</span>
          </button>
        </div>
        <div class="d-flex align-items-center gap-3">
          <small class="text-secondary" id="resultCount"></small>
          <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addLeadModal">
            <i class="bi bi-plus-lg me-1"></i>Add Lead
          </button>
        </div>
      </div>

      <!-- Leads Table -->
      <div class="dash-card p-0">
        <% if (leads.length > 0) { %>
          <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
              <thead>
                <tr>
                  <th class="text-secondary small text-uppercase ps-4">Name</th>
                  <th class="text-secondary small text-uppercase">Email</th>
                  <th class="text-secondary small text-uppercase">Phone</th>
                  <th class="text-secondary small text-uppercase">Company</th>
                  <th class="text-secondary small text-uppercase">Status</th>
                  <th class="text-secondary small text-uppercase">Date</th>
                  <th class="text-secondary small text-uppercase text-end pe-4">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% leads.forEach(function(lead) { %>
                  <tr data-name="<%= lead.name.toLowerCase() %>"
                      data-email="<%= (lead.email || '').toLowerCase() %>"
                      data-phone="<%= (lead.phone || '').toLowerCase() %>"
                      data-company="<%= (lead.company || '').toLowerCase() %>"
                      data-status="<%= lead.status %>"
                      data-date="<%= new Date(lead.createdAt).getTime() %>">
                    <td class="fw-semibold ps-4"><%= lead.name %></td>
                    <td class="text-secondary"><%= lead.email || '—' %></td>
                    <td class="text-secondary"><%= lead.phone || '—' %></td>
                    <td class="text-secondary"><%= lead.company || '—' %></td>
                    <td>
                      <span class="badge rounded-pill
                        <% if (lead.status==='lead') { %>bg-warning-subtle text-warning
                        <% } else if (lead.status==='prospect') { %>bg-info-subtle text-info
                        <% } else { %>bg-secondary-subtle text-secondary<% } %>
                      "><%= lead.status %></span>
                    </td>
                    <td class="text-secondary small"><%= new Date(lead.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></td>
                    <td class="text-end pe-4">
                      <button class="btn btn-sm btn-outline-secondary py-0 px-2 me-1"
                              onclick="openEditModal('<%= lead._id %>')">
                        <i class="bi bi-pencil"></i>
                      </button>
                      <button class="btn btn-sm btn-outline-danger py-0 px-2"
                              data-lead-id="<%= lead._id %>"
                              data-lead-name="<%= lead.name %>"
                              onclick="openDeleteModal(this.dataset.leadId, this.dataset.leadName)">
                        <i class="bi bi-trash"></i>
                      </button>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
          <div class="px-4 py-3 border-top border-secondary border-opacity-10">
            <small class="text-secondary">Showing <strong class="text-white"><%= leads.length %></strong> lead<%= leads.length !== 1 ? 's' : '' %></small>
          </div>
        <% } else { %>
          <div class="text-center py-5">
            <i class="bi bi-funnel text-secondary" style="font-size:2.5rem;opacity:0.4;"></i>
            <p class="text-secondary mt-2 mb-3">No leads found</p>
            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addLeadModal">Add First Lead</button>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- ========== ADD LEAD MODAL ========== -->
<div class="modal fade" id="addLeadModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark border-secondary border-opacity-25" style="border-radius:16px;">
      <div class="modal-header border-secondary border-opacity-10">
        <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2 text-primary"></i>Add New Lead</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form action="/leads" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label small text-secondary">Name *</label>
              <input type="text" name="name" class="form-control bg-dark border-secondary border-opacity-25 text-white" placeholder="John Doe" required />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Email</label>
              <input type="email" name="email" class="form-control bg-dark border-secondary border-opacity-25 text-white" placeholder="john@example.com" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Phone</label>
              <input type="text" name="phone" class="form-control bg-dark border-secondary border-opacity-25 text-white" placeholder="+1 555 000-0000" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Company</label>
              <input type="text" name="company" class="form-control bg-dark border-secondary border-opacity-25 text-white" placeholder="Acme Inc." />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Status</label>
              <select name="status" class="form-select bg-dark border-secondary border-opacity-25 text-white">
                <option value="lead">Lead</option>
                <option value="prospect">Prospect</option>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label small text-secondary">Notes</label>
              <textarea name="notes" rows="2" class="form-control bg-dark border-secondary border-opacity-25 text-white" placeholder="Additional notes..."></textarea>
            </div>
          </div>
        </div>
        <div class="modal-footer border-secondary border-opacity-10">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Lead</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ========== EDIT LEAD MODAL ========== -->
<div class="modal fade" id="editLeadModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content bg-dark border-secondary border-opacity-25" style="border-radius:16px;">
      <div class="modal-header border-secondary border-opacity-10">
        <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2 text-primary"></i>Edit Lead</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <form id="editLeadForm" method="POST">
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-12">
              <label class="form-label small text-secondary">Name *</label>
              <input type="text" name="name" id="editName" class="form-control bg-dark border-secondary border-opacity-25 text-white" required />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Email</label>
              <input type="email" name="email" id="editEmail" class="form-control bg-dark border-secondary border-opacity-25 text-white" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Phone</label>
              <input type="text" name="phone" id="editPhone" class="form-control bg-dark border-secondary border-opacity-25 text-white" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Company</label>
              <input type="text" name="company" id="editCompany" class="form-control bg-dark border-secondary border-opacity-25 text-white" />
            </div>
            <div class="col-md-6">
              <label class="form-label small text-secondary">Status</label>
              <select name="status" id="editStatus" class="form-select bg-dark border-secondary border-opacity-25 text-white">
                <option value="lead">Lead</option>
                <option value="prospect">Prospect</option>
              </select>
            </div>
            <div class="col-12">
              <label class="form-label small text-secondary">Notes</label>
              <textarea name="notes" id="editNotes" rows="2" class="form-control bg-dark border-secondary border-opacity-25 text-white"></textarea>
            </div>
          </div>
        </div>
        <div class="modal-footer border-secondary border-opacity-10">
          <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Update Lead</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- ========== DELETE CONFIRMATION MODAL ========== -->
<div class="modal fade" id="deleteLeadModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content bg-dark border-danger border-opacity-25" style="border-radius:16px;">
      <div class="modal-body text-center py-4">
        <div class="mb-3">
          <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:2.5rem;"></i>
        </div>
        <h5 class="fw-bold text-white mb-2">Delete Lead</h5>
        <p class="text-secondary small mb-0">Are you sure you want to delete <strong class="text-white" id="deleteLeadName"></strong>?</p>
        <p class="text-secondary small">This action cannot be undone.</p>
      </div>
      <div class="modal-footer border-secondary border-opacity-10 justify-content-center">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <form id="deleteLeadForm" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  // State
  let currentFilter = 'all';
  let sortAsc = false; // false = newest first

  // DOM refs
  const searchInput = document.getElementById('leadSearch');
  const pills = document.querySelectorAll('.filter-pill');
  const sortToggle = document.getElementById('sortToggle');
  const sortIcon = document.getElementById('sortIcon');
  const sortLabel = document.getElementById('sortLabel');
  const resultCount = document.getElementById('resultCount');
  const tbody = document.querySelector('table tbody');
  const emptyState = document.querySelector('.dash-card .text-center.py-5');

  // -------- FILTER & SEARCH --------
  function applyFilters() {
    if (!tbody) return;
    const query = (searchInput ? searchInput.value : '').toLowerCase().trim();
    const rows = Array.from(tbody.querySelectorAll('tr'));
    let visible = 0;

    rows.forEach(row => {
      const name = row.dataset.name || '';
      const email = row.dataset.email || '';
      const phone = row.dataset.phone || '';
      const company = row.dataset.company || '';
      const status = row.dataset.status || '';

      // Status filter
      const statusMatch = currentFilter === 'all' || status === currentFilter;

      // Search filter
      const searchMatch = !query ||
        name.includes(query) ||
        email.includes(query) ||
        phone.includes(query) ||
        company.includes(query);

      if (statusMatch && searchMatch) {
        row.style.display = '';
        row.style.animation = 'fadeRow 0.25s ease';
        visible++;
      } else {
        row.style.display = 'none';
        row.style.animation = '';
      }
    });

    // Update count
    if (resultCount) {
      resultCount.textContent = visible + ' of ' + rows.length + ' lead' + (rows.length !== 1 ? 's' : '');
    }

    // Show/hide empty state in footer
    const footer = document.querySelector('.px-4.py-3.border-top');
    if (footer) {
      const strong = footer.querySelector('strong');
      if (strong) strong.textContent = visible;
    }
  }

  // -------- SORT --------
  function applySort() {
    if (!tbody) return;
    const rows = Array.from(tbody.querySelectorAll('tr'));
    rows.sort((a, b) => {
      const da = parseInt(a.dataset.date) || 0;
      const db = parseInt(b.dataset.date) || 0;
      return sortAsc ? da - db : db - da;
    });
    rows.forEach(row => tbody.appendChild(row));
  }

  // -------- EVENT LISTENERS --------

  // Live search with debounce
  let debounceTimer;
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(applyFilters, 150);
    });
  }

  // Status pills
  pills.forEach(pill => {
    pill.addEventListener('click', function() {
      pills.forEach(p => p.classList.remove('active'));
      this.classList.add('active');
      currentFilter = this.dataset.status;
      applyFilters();
    });
  });

  // Sort toggle
  if (sortToggle) {
    sortToggle.addEventListener('click', function() {
      sortAsc = !sortAsc;
      sortIcon.className = sortAsc ? 'bi bi-sort-up' : 'bi bi-sort-down';
      sortLabel.textContent = sortAsc ? 'Oldest' : 'Newest';
      applySort();
    });
  }

  // Init
  applyFilters();
})();

// Edit modal: fetch lead data and populate form
async function openEditModal(id) {
  try {
    const res = await fetch('/leads/' + id + '/json');
    const lead = await res.json();
    document.getElementById('editLeadForm').action = '/leads/' + id;
    document.getElementById('editName').value = lead.name || '';
    document.getElementById('editEmail').value = lead.email || '';
    document.getElementById('editPhone').value = lead.phone || '';
    document.getElementById('editCompany').value = lead.company || '';
    document.getElementById('editStatus').value = lead.status || 'lead';
    document.getElementById('editNotes').value = lead.notes || '';
    new bootstrap.Modal(document.getElementById('editLeadModal')).show();
  } catch (err) {
    console.error(err);
  }
}

// Delete modal
function openDeleteModal(id, name) {
  document.getElementById('deleteLeadForm').action = '/leads/' + id + '/delete';
  document.getElementById('deleteLeadName').textContent = name;
  new bootstrap.Modal(document.getElementById('deleteLeadModal')).show();
}
</script>

<style>
  /* Filter pill styles */
  .filter-pill {
    background: rgba(30, 41, 59, 0.8);
    color: #94a3b8;
    cursor: pointer;
    transition: all 0.2s ease;
    border: 1px solid rgba(148,163,184,0.1) !important;
  }
  .filter-pill:hover {
    background: rgba(99,102,241,0.1);
    color: #c7d2fe;
  }
  .filter-pill.active {
    background: #6366f1 !important;
    color: #fff !important;
    border-color: #6366f1 !important;
  }
  @keyframes fadeRow {
    from { opacity: 0; transform: translateY(-4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
